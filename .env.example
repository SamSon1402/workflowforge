# --- Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workflowforge?schema=public"

# --- Temporal (run locally via `temporal server start-dev`)
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="workflowforge"

# --- Anthropic (used by the NL → DSL compiler)
ANTHROPIC_API_KEY="sk-ant-..."

# --- Inngest (handles cron-triggered workflows)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
